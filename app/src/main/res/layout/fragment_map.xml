<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    tools:context=".ui.map.MapFragment">

    <ViewSwitcher
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/map_table">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:context=".MapsFragment" />

    </ViewSwitcher>

    <TableLayout
        android:id="@+id/map_table"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:stretchColumns="0,1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TableRow
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:padding="2dip">

            <TextView
                android:id="@+id/map_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distance"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:textAppearance="@style/LabelText"
                android:textColor="@color/primary_text" />

            <TextView
                android:id="@+id/map_target_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="Target\nPosition"
                android:layout_weight="10"
                android:textAppearance="@style/LabelText"
                android:textColor="@color/primary_text" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                tools:layout_editor_absoluteX="1dp">

                <AutoCompleteTextView
                    android:id="@+id/mapType"
                    android:layout_height="wrap_content"
                    android:text="Map Type"
                    android:inputType="none"
                    android:layout_width="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>
        </TableRow>

        <TableRow
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:padding="2dip">

            <TextView
                android:id="@+id/map_bearing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:text="Bearing"
                android:textAppearance="@style/LabelText"
                android:textColor="@color/primary_text" />

            <TextView
                android:id="@+id/map_receiver_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="10"
                android:text="Receiver\nPosition"
                android:textAppearance="@style/LabelText"
                android:textColor="@color/primary_text" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/map_online"
                style="@style/SwitchButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:background="@color/primary_background"
                android:text="@string/map_online"
                android:textAppearance="@style/ButtonText"
                android:textColor="@color/primary_text" />
        </TableRow>
    </TableLayout>




</androidx.constraintlayout.widget.ConstraintLayout>