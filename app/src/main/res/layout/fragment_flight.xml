	<androidx.constraintlayout.widget.Barrier
            android:id="@+id/altitude_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="altitude_label,altitude_value"/>

	<androidx.constraintlayout.widget.Group
            android:id="@+id/tilt_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="visible"
            app:constraint_referenced_ids="tilt_label,tilt_value"/>

	<TextView
            android:id="@+id/tilt_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column="2"
            android:textAppearance="@style/LabelText"
            android:text="@string/tilt_label"
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_good"
            app:layout_constraintEnd_toStartOf="@id/column_name"
            app:layout_constraintTop_toTopOf="@id/altitude_row"
            app:layout_constraintBottom_toTopOf="@id/tilt_row" />

	<TextView
            android:id="@+id/tilt_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/altitude_row"
            app:layout_constraintBottom_toTopOf="@id/tilt_row" />

	<androidx.constraintlayout.widget.Barrier
            android:id="@+id/tilt_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tilt_label,tilt_value"/>

	<TextView
            android:id="@+id/max_speed_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column="2"
            android:textAppearance="@style/LabelText"
            android:text="@string/max_speed_label"
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_good"
            app:layout_constraintEnd_toStartOf="@id/column_name"
            app:layout_constraintTop_toTopOf="@id/tilt_row"
            app:layout_constraintBottom_toTopOf="@id/max_speed_row" />

	<TextView
            android:id="@+id/max_speed_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tilt_row"
            app:layout_constraintBottom_toTopOf="@id/max_speed_row" />

	<androidx.constraintlayout.widget.Barrier
            android:id="@+id/max_speed_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="max_speed_label,max_speed_value"/>

	<TextView
            android:id="@+id/max_height_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column="2"
            android:textAppearance="@style/LabelText"
            android:text="@string/max_height_label"
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_good"
            app:layout_constraintEnd_toStartOf="@id/column_name"
            app:layout_constraintTop_toTopOf="@id/max_speed_row"
