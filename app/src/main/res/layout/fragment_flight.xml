	<TextView
            android:id="@+id/bearing_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column="2"
            android:textAppearance="@style/LabelText"
            android:text="@string/bearing_label"
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_good"
            app:layout_constraintEnd_toStartOf="@id/column_name"
            app:layout_constraintTop_toTopOf="@id/range_row"
            app:layout_constraintBottom_toTopOf="@id/bearing_row" />

	<TextView
            android:id="@+id/bearing_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/range_row"
            app:layout_constraintBottom_toTopOf="@id/bearing_row" />

	<androidx.constraintlayout.widget.Barrier
            android:id="@+id/bearing_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="bearing_label,bearing_value"/>

	<TextView
            android:id="@+id/compass_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/bearing_row"
            app:layout_constraintBottom_toTopOf="@id/compass_row" />

	<androidx.constraintlayout.widget.Barrier
            android:id="@+id/compass_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="compass_value"/>

	<TextView
            android:id="@+id/distance_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column="2"
            android:textAppearance="@style/LabelText"
            android:text="@string/gnd_distance_label"
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_good"
            app:layout_constraintEnd_toStartOf="@id/column_name"
            app:layout_constraintTop_toTopOf="@id/compass_row"
            app:layout_constraintBottom_toTopOf="@id/distance_row" />

	<TextView
            android:id="@+id/distance_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/compass_row"
            app:layout_constraintBottom_toTopOf="@id/distance_row" />

	<androidx.constraintlayout.widget.Barrier
            android:id="@+id/distance_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="distance_label,distance_value"/>

	<ImageView
            android:id="@+id/target_pos_icon"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerInside"
            android:paddingStart="@dimen/table_padding_start"
            android:paddingEnd="10dp"
            android:contentDescription="@string/target_position_label"
            android:src="@drawable/flight_orange"
            app:layout_constrainedHeight="true"
            app:layout_constrainedWidth="true"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/column_good"
            app:layout_constraintTop_toTopOf="@id/distance_row"
            app:layout_constraintBottom_toTopOf="@id/lon_row"/>

	<TextView
            android:id="@+id/lat_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_column="2"
            android:textAppearance="@style/LabelText"
            android:text="@string/latitude_label"
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_good"
            app:layout_constraintEnd_toStartOf="@id/column_name"
            app:layout_constraintTop_toTopOf="@id/distance_row"
            app:layout_constraintBottom_toTopOf="@id/lat_row" />

	<TextView
            android:id="@+id/lat_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
