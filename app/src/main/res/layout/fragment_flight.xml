	<androidx.constraintlayout.widget.Group
            android:id="@+id/apogee_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="visible"
            app:constraint_referenced_ids="apogee_redled,apogee_greenled,apogee_voltage_label,apogee_voltage_value"/>

	<ImageView
            android:id="@+id/apogee_redled"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerInside"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:contentDescription="@string/apogee_voltage_label"
            android:src="@drawable/grayled"
            app:layout_constrainedHeight="true"
            app:layout_constrainedWidth="true"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/column_bad"
            app:layout_constraintTop_toTopOf="@id/lon_row"
            app:layout_constraintBottom_toTopOf="@id/apogee_row" />

	<ImageView
            android:id="@+id/apogee_greenled"
            android:layout_width="0dp"
            android:layout_height="0dp"
