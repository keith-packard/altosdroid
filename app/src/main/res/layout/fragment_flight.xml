	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_good"
            app:layout_constraintEnd_toStartOf="@id/column_name"
            app:layout_constraintTop_toTopOf="@id/max_height_row"
            app:layout_constraintBottom_toTopOf="@id/max_altitude_row" />

	<TextView
            android:id="@+id/max_altitude_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/max_height_row"
            app:layout_constraintBottom_toTopOf="@id/max_altitude_row" />

	<androidx.constraintlayout.widget.Barrier
            android:id="@+id/max_altitude_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="max_altitude_label,max_altitude_value"/>

	<TextView
            android:id="@+id/elevation_label"
