<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:context=".ui.flight.FlightFragment">

	<androidx.constraintlayout.widget.Guideline
            android:id="@+id/column_bad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent=".06"/>

	<androidx.constraintlayout.widget.Guideline
            android:id="@+id/column_good"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent=".12"/>

	<androidx.constraintlayout.widget.Guideline
            android:id="@+id/column_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
	    android:orientation="vertical"
            app:layout_constraintGuide_percent=".50"/>

	<TextView
            android:id="@+id/speed_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="@style/LabelText"
            android:text="@string/speed_label"
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_good"
            app:layout_constraintEnd_toStartOf="@id/column_name"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/speed_row" />

	<TextView
            android:id="@+id/speed_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/speed_row"/>

	<androidx.constraintlayout.widget.Barrier
            android:id="@+id/speed_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="speed_label,speed_value"/>

	<TextView
            android:id="@+id/height_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="@style/LabelText"
            android:text="@string/height_label"
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_good"
            app:layout_constraintEnd_toStartOf="@id/column_name"
            app:layout_constraintTop_toTopOf="@id/speed_row"
            app:layout_constraintBottom_toTopOf="@id/height_row" />

	<TextView
            android:id="@+id/height_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/speed_row"
            app:layout_constraintBottom_toTopOf="@id/height_row" />

	<androidx.constraintlayout.widget.Barrier
            android:id="@+id/height_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="height_label,height_value"/>

	<TextView
            android:id="@+id/altitude_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="@style/LabelText"
            android:text="@string/altitude_label"
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_good"
            app:layout_constraintEnd_toStartOf="@id/column_name"
            app:layout_constraintTop_toTopOf="@id/height_row"
            app:layout_constraintBottom_toTopOf="@id/altitude_row" />

	<TextView
            android:id="@+id/altitude_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
	    android:paddingVertical="@dimen/table_padding_vertical"
            app:layout_constraintStart_toStartOf="@id/column_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/height_row"
