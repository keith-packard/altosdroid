<resources>
    <!-- Base application theme. -->
    <style name="Theme.AltosDroid" parent="Theme.MaterialComponents.DayNight">

		<item name="android:colorBackground">#ffffff</item>
		<item name="colorOnBackground">#ff0000</item>

		<item name="colorPrimary">#ff8000</item>
		<item name="colorPrimaryVariant">#808000</item>
		<item name="colorOnPrimary">#0000ff</item>
		<item name="android:windowLightStatusBar">true</item>

    </style>
	<style name="LabelText" parent="TextAppearance.AppCompat">
		<item name="android:textSize">18sp</item>
	</style>
	<style name="ValueText" parent="LabelText">
		<item name="android:textStyle">bold</item>
	</style>
	<style name="PosText" parent="ValueText">
	</style>
	<style name="ButtonText" parent="LabelText">
	</style>
	<style name="DeviceText" parent="ValueText">
	</style>
	<style name="AgeOk" parent="ValueText">
		<item name="android:textColor">@color/age_ok</item>
	</style>
	<style name="AgeWarn" parent="ValueText">
		<item name="android:textColor">@color/age_warn</item>
	</style>
	<style name="AgeError" parent="ValueText">
		<item name="android:textColor">@color/age_error</item>
	</style>
</resources>
